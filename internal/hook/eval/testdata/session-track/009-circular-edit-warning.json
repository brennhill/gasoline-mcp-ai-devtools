      {"t": "2026-03-07T14:01:00Z", "tool": "Edit", "file": "/p/handler.go", "action": "edit", "summary": "first attempt"},
      {"t": "2026-03-07T14:02:00Z", "tool": "Read", "file": "/p/routes.go", "action": "read"},
      {"t": "2026-03-07T14:03:00Z", "tool": "Edit", "file": "/p/routes.go", "action": "edit", "summary": "add route"},
      {"t": "2026-03-07T14:04:00Z", "tool": "Bash", "file": "", "action": "bash", "summary": "go test ./... FAIL"}
