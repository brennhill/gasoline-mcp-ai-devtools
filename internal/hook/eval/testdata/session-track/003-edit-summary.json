{
  "description": "Edit a file with session history — should inject session summary",
  "hook": "session-track",
  "session_state": {
    "touches": [
      {"t": "2026-03-07T14:00:00Z", "tool": "Read", "file": "/project/handlers.go", "action": "read"},
      {"t": "2026-03-07T14:01:00Z", "tool": "Read", "file": "/project/routes.go", "action": "read"},
      {"t": "2026-03-07T14:02:00Z", "tool": "Bash", "file": "", "action": "bash", "summary": "go test ./..."}
