{
  "description": "Re-read a file already read — should warn about redundant read",
  "hook": "session-track",
  "session_state": {
    "touches": [
      {"t": "2026-03-07T14:00:00Z", "tool": "Read", "file": "/project/handlers.go", "action": "read"}
    ]
  },
  "input": {
    "tool_name": "Read",
    "tool_input": {"file_path": "/project/handlers.go"}
  },
  "expect": {
    "has_output": true,
    "contains": ["[Session]", "You read this file"],
    "max_latency_ms": 100
  }
}
