{
  "description": "Edit a Go file in the gasoline project — should inject code standards",
  "hook": "quality-gate",
  "project_root": "REPO_ROOT",
  "input": {
    "tool_name": "Edit",
    "tool_input": {"file_path": "internal/hook/protocol.go", "new_string": "func HandleUser(w http.ResponseWriter, r *http.Request) {"}
  },
  "expect": {
    "has_output": true,
    "contains": ["PROJECT CODE STANDARDS", "Max 800 lines"],
    "max_latency_ms": 500
  }
}
