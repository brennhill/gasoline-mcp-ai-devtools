---
// TableOfContents.astro — Custom TOC with Sparky at bottom
import Default from '@astrojs/starlight/components/TableOfContents.astro';
---

<div class="toc-wrapper">
  <Default><slot /></Default>
  <aside class="sparky-toc-widget">
    <img 
      src="/images/sparky-reading-sidebar.png" 
      alt="Sparky the Salamander reading Cook with Gasoline" 
      class="sparky-toc-image"
    />
  </aside>
</div>

<style>
  .toc-wrapper {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .sparky-toc-widget {
    margin-top: auto;
    padding: 0.75rem 0;
    display: flex;
    justify-content: center;
    border-top: 1px solid var(--sl-color-gray-5);
  }

  .sparky-toc-image {
    max-width: 100%;
    height: auto;
    max-height: 150px;
  }
</style>
