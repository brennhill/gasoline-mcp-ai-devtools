---
// Analytics.astro — Google Analytics with custom event tracking
// Set PUBLIC_GA_ID environment variable in .env to enable analytics
// Example: PUBLIC_GA_ID=G-XXXXXXXXXX
// Includes AI-friendly content signal meta for headless agents.
const gaId = import.meta.env.PUBLIC_GA_ID;
---

{gaId && (
  <>
    <!-- Google Analytics -->
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
  </>
)}

<script define:vars={{ gaId }}>
  // Initialize Google Analytics if GA_ID is configured
  if (gaId && gaId !== 'G-XXXXXXXXXX') {
    window.dataLayer = window.dataLayer || [];
    function gtag() {
      dataLayer.push(arguments);
    }
    gtag('js', new Date());
    gtag('config', gaId, {
      'anonymize_ip': true,
      'allow_google_signals': false
    });
  }

  // Track extension download clicks
  document.addEventListener('DOMContentLoaded', () => {
    // Track all download CRX links
    document.querySelectorAll('a[href*=".crx"]').forEach(link => {
      link.addEventListener('click', () => {
        gtag('event', 'extension_download', {
          'event_category': 'downloads',
          'event_label': 'chrome_extension',
          'value': 1
        });
      });
    });

    // Track "Get Started" and "Download Now" buttons
    document.querySelectorAll('a[href*="downloads"]').forEach(link => {
      link.addEventListener('click', () => {
        gtag('event', 'download_page_visit', {
          'event_category': 'downloads',
          'event_label': link.textContent.trim(),
          'value': 1
        });
      });
    });

    // Track documentation page views
    gtag('event', 'page_view', {
      'page_title': document.title,
      'page_location': window.location.href,
      'page_path': new URL(window.location.href).pathname
    });

    // Track outbound link clicks (GitHub, Discord, external resources)
    document.querySelectorAll('a[href^="http"]').forEach(link => {
      // Skip internal links to gokaboom.dev
      if (!link.href.includes('gokaboom.dev')) {
        link.addEventListener('click', () => {
          const hostname = new URL(link.href).hostname;
          gtag('event', 'outbound_click', {
            'event_category': 'outbound',
            'event_label': hostname,
            'event_value': 1,
            'outbound_url': link.href
          });
        });
      }
    });

    // Track MCP configuration clicks
    document.querySelectorAll('a[href*="mcp-integration"]').forEach(link => {
      link.addEventListener('click', () => {
        gtag('event', 'mcp_integration_view', {
          'event_category': 'integration',
          'event_label': link.textContent.trim()
        });
      });
    });

    // Track Getting Started button clicks
    document.querySelectorAll('a[href*="getting-started"]').forEach(link => {
      link.addEventListener('click', () => {
        gtag('event', 'getting_started_click', {
          'event_category': 'engagement',
          'event_label': 'getting_started'
        });
      });
    });

    // Track feature exploration
    document.querySelectorAll('a[href*="features"]').forEach(link => {
      link.addEventListener('click', () => {
        gtag('event', 'features_view', {
          'event_category': 'engagement',
          'event_label': 'features_page'
        });
      });
    });
  });
</script>
