---
import { getCollection } from 'astro:content';
import { resolveDocSlug } from '../utils/contentSlugs';

const stripMarkdown = (content: string) =>
  content
    .replace(/```[\s\S]*?```/g, ' ')
    .replace(/`[^`]*`/g, ' ')
    .replace(/!\[[^\]]*\]\([^)]*\)/g, ' ')
    .replace(/\[[^\]]*\]\([^)]*\)/g, ' ')
    .replace(/[#>*_~-]/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();

const toTopicLabel = (topic: string) =>
  topic
    .replace(/[-_]/g, ' ')
    .split(' ')
    .filter(Boolean)
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(' ');

const topicAnchor = (topic: string) =>
  `topic-${topic
    .toLowerCase()
    .replace(/[^a-z0-9\s-]/g, '')
    .trim()
    .replace(/\s+/g, '-')}`;

const docs = await getCollection('docs');
const articleEntries = docs.filter((entry) => resolveDocSlug(entry).startsWith('articles/'));

const articles = articleEntries
  .map((entry) => {
    const slug = resolveDocSlug(entry);
    const parsedDate = entry.data.date ? new Date(entry.data.date) : new Date(0);
    const tags = Array.isArray(entry.data.tags) ? entry.data.tags.map((tag) => String(tag).toLowerCase()) : [];
    const excerptSource = String(entry.data.description || '').trim() || stripMarkdown(entry.body).slice(0, 260);
    const primaryTopic = tags[0] || 'general';

    return {
      slug: `/${slug}/`,
      title: entry.data.title || 'Untitled Article',
      excerpt: excerptSource,
      dateISO: Number.isNaN(parsedDate.getTime()) ? '1970-01-01T00:00:00.000Z' : parsedDate.toISOString(),
      dateLabel: Number.isNaN(parsedDate.getTime())
        ? 'Unknown date'
        : parsedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }),
      tags,
      primaryTopic,
    };
  })
  .sort((a, b) => b.dateISO.localeCompare(a.dateISO));

const byTopic = new Map<string, typeof articles>();

for (const article of articles) {
  if (!byTopic.has(article.primaryTopic)) {
    byTopic.set(article.primaryTopic, []);
  }
  byTopic.get(article.primaryTopic)?.push(article);
}

const topicSections = Array.from(byTopic.entries())
  .map(([topic, topicArticles]) => ({
    topic,
    label: toTopicLabel(topic),
    anchor: topicAnchor(topic),
    count: topicArticles.length,
    articles: topicArticles.sort((a, b) => b.dateISO.localeCompare(a.dateISO)),
  }))
  .sort((a, b) => a.label.localeCompare(b.label));
---

<section class="articles-library-shell">
  <div class="articles-library-hero">
    <p class="landing-eyebrow">ARTICLES</p>
    <h2>Topic-first guides for building with KaBOOM</h2>
    <p>
      Articles are organized by topic so readers can follow a learning path. Each post still includes a publish date and an
      agent-friendly markdown route.
    </p>
  </div>

  <div class="articles-topic-nav" aria-label="Article topics">
    {
      topicSections.map((section) => (
        <a href={`#${section.anchor}`} class="articles-topic-chip">
          <span>{section.label}</span>
          <small>{section.count}</small>
        </a>
      ))
    }
  </div>

  {
    topicSections.map((section) => (
      <section id={section.anchor} class="articles-topic-section">
        <header class="articles-topic-header">
          <h3>{section.label}</h3>
          <p>{section.count} article{section.count === 1 ? '' : 's'}</p>
        </header>

        <div class="articles-grid">
          {
            section.articles.map((article) => (
              <article class="article-card">
                <div class="article-card-top">
                  <span class="article-tag">{toTopicLabel(article.primaryTopic)}</span>
                  <time datetime={article.dateISO}>{article.dateLabel}</time>
                </div>
                <h4>{article.title}</h4>
                <p>{article.excerpt}</p>
                <div class="article-card-bottom">
                  <a href={article.slug}>Read article</a>
                  <a href={`${article.slug.replace(/\/$/, '')}.md`} class="article-md-link">Agent markdown</a>
                </div>
              </article>
            ))
          }
        </div>
      </section>
    ))
  }
</section>
