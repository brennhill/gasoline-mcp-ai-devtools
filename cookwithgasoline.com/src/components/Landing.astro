  <meta property="og:title" content="Gasoline MCP: Enabling Full-stack Automated AI Debugging">
  <meta property="og:description" content="Gasoline MCP is an open-source browser extension + MCP server for AI coding assistants. See everything, fix anything.">
  <meta property="og:image" content="/images/og-default.png">
  <meta property="og:image:width" content="1280">
  <meta property="og:image:height" content="640">
  <meta property="og:image:type" content="image/png">
  <meta property="og:url" content="https://cookwithgasoline.com/">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Gasoline MCP: Enabling Full-stack Automated AI Debugging">
  <meta name="twitter:description" content="Gasoline MCP is an open-source browser extension + MCP server for AI coding assistants. See everything, fix anything.">
  <meta name="twitter:image" content="/images/og-default.png">
