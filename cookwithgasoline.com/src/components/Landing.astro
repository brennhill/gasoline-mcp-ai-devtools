---
import { workflowPresets } from '../data/workflows';

const featuredWorkflows = workflowPresets.slice(0, 6);
---

<div class="landing-shell">
  <section class="landing-banner" aria-label="Capability tags">
    <p class="landing-eyebrow">BROWSER REALITY FOR AI BUILDERS</p>
    <div class="landing-tags">
      <span>Automation</span>
      <span>Debugging</span>
      <span>Demo Recording</span>
      <span>Interactive Development</span>
      <span>Performance</span>
      <span>Security</span>
    </div>
  </section>

  <section class="section-grid section-grid--hero-followup" id="why-gasoline">
    <div>
      <h2>Why screen actions beat prompt-only web agents</h2>
      <p>
        Most AI coding workflows stop at code suggestions. Gasoline closes the loop by streaming what the browser is actually doing,
        then letting your agent interact, verify, and document the result.
      </p>
      <ul class="value-list">
        <li>Observe real console, network, and WebSocket failures from the live session.</li>
        <li>Act in the browser with deterministic interactions, not screenshot guessing.</li>
        <li>Generate reusable demos and tests from the exact path users took.</li>
      </ul>
      <a href="/guides/debug-webapps/" class="soft-link">See debugging guide</a>
    </div>

    <div class="signal-graphic" role="img" aria-label="Live browser telemetry graphic">
      <div class="graphic-header">
        <span></span><span></span><span></span>
        <p>Browser Session Feed</p>
      </div>
      <div class="signal-row row-error">
        <strong>TypeError</strong>
        <span>checkout.tsx:341</span>
      </div>
      <div class="signal-row row-warn">
        <strong>502 /api/pricing</strong>
        <span>retry in 1.5s</span>
      </div>
      <div class="signal-row row-info">
        <strong>WS reconnect</strong>
        <span>socket reopened</span>
      </div>
      <div class="signal-row row-ok">
        <strong>fix verified</strong>
        <span>green across checks</span>
      </div>
      <div class="wave-bars" aria-hidden="true">
        <i></i><i></i><i></i><i></i><i></i><i></i><i></i><i></i>
      </div>
    </div>
  </section>

  <section class="section-block" id="closed-loop">
    <h2>Record. Diagnose. Patch. Verify.</h2>
    <p class="section-lead">
      The same interface handles capture, analysis, and verification so your team can move from "something is broken" to "fix confirmed" in one pass.
    </p>
    <div class="loop-grid">
      <article class="loop-card">
        <span class="loop-step">01</span>
        <h3>Record browser truth</h3>
        <p>Capture user actions, network payloads, logs, and visual state from the exact environment where issues happen.</p>
      </article>
      <article class="loop-card">
        <span class="loop-step">02</span>
        <h3>Debug with context</h3>
        <p>Cluster errors, inspect response bodies, and follow timeline signals that connect cause and symptom.</p>
      </article>
      <article class="loop-card">
        <span class="loop-step">03</span>
        <h3>Ship with evidence</h3>
        <p>Replay flows, generate tests, and attach screenshots or SARIF output so releases are defensible.</p>
      </article>
    </div>
  </section>

  <section class="section-block" id="use-cases">
    <h2>Built for real web delivery work</h2>
    <div class="use-case-grid">
      <article class="use-case-card">
        <h3>Automation</h3>
        <p>Run smoke paths, repetitive QA steps, and cross-page checks through stable selectors and scripted actions.</p>
      </article>
      <article class="use-case-card">
        <h3>Debugging</h3>
        <p>Triage incidents with one timeline that includes logs, fetch bodies, and UI state mutations.</p>
      </article>
      <article class="use-case-card">
        <h3>Demo recording</h3>
        <p>Turn PM walkthroughs into repeatable scripted demos and regression-ready artifacts for launch reviews.</p>
      </article>
      <article class="use-case-card">
        <h3>Interactive development</h3>
        <p>Ask your agent to query DOM state, trigger interactions, and validate behavior while coding.</p>
      </article>
    </div>
  </section>

  <section class="section-block" id="workflow-preview">
    <div class="section-headline-row">
      <h2>Workflow Library</h2>
      <a href="/discover-workflows/" class="soft-link">Explore all workflows</a>
    </div>
    <p class="section-lead">Prebuilt flows you can run as-is or adapt to your own product stack.</p>
    <div class="workflow-preview-grid">
      {
        featuredWorkflows.map((workflow) => (
          <article class="workflow-preview-card">
            <div class="workflow-preview-top">
              <span class="workflow-category">{workflow.category}</span>
              <span class="workflow-runtime">{workflow.runtime}</span>
            </div>
            <h3>{workflow.title}</h3>
            <p>{workflow.summary}</p>
            <a href={workflow.docPath}>Open playbook</a>
          </article>
        ))
      }
    </div>
  </section>

  <section class="theme-callout" aria-label="Theme support">
    <img src="/images/sparky-thumbs-up-transparent.png" alt="Sparky giving a thumbs up" class="theme-callout-image" loading="lazy" />
    <div>
      <h3>Light and dark theme support is enabled</h3>
      <p>
        Use the theme switch in the header to review the full landing and workflow library in both modes.
      </p>
      <a class="btn" href="/getting-started/">Get started in under five minutes</a>
    </div>
  </section>
</div>
