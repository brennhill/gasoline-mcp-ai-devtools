---
// Sidebar.astro — Custom Gasoline sidebar with Sparky mascot at bottom
import Default from '@astrojs/starlight/components/Sidebar.astro';
---

<div class="sidebar-wrapper">
  <Default><slot /></Default>
  <aside class="sparky-sidebar-widget">
    <img 
      src="/images/sparky-reading-sidebar.png" 
      alt="Sparky the Salamander reading Cook with Gasoline" 
      class="sparky-sidebar-image"
    />
  </aside>
</div>

<style>
  .sidebar-wrapper {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .sparky-sidebar-widget {
    margin-top: auto;
    padding: 1rem;
    display: flex;
    justify-content: center;
    border-top: 1px solid var(--sl-color-gray-5);
  }

  .sparky-sidebar-image {
    max-width: 100%;
    height: auto;
    max-height: 180px;
  }
</style>
