---
import { workflowPresets } from '../data/workflows';
import type { WorkflowCategory } from '../data/workflows';

const categories = ['All', ...new Set(workflowPresets.map((workflow) => workflow.category))];
const workflowsByNewest = [...workflowPresets].sort((a, b) => b.updatedAt.localeCompare(a.updatedAt));

const categoryMeta: Record<WorkflowCategory, { color: string; icon: string }> = {
  Automation: {
    color: '#e67e22',
    icon: '<path d="M12 8V4l8 8-8 8v-4H4V8h8z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>',
  },
  Debugging: {
    color: '#3b82f6',
    icon: '<path d="M12 2a4 4 0 0 0-4 4v1H6l-1 3h2v3H5l-1 4h3v1a5 5 0 0 0 10 0v-1h3l-1-4h-2v-3h2l-1-3h-2V6a4 4 0 0 0-4-4z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>',
  },
  'Demo Recording': {
    color: '#ef4444',
    icon: '<circle cx="12" cy="12" r="4" fill="currentColor"/><circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="1.8"/>',
  },
  'Interactive Development': {
    color: '#8b5cf6',
    icon: '<path d="M7 8l-4 4 4 4M17 8l4 4-4 4M14 4l-4 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>',
  },
  Reliability: {
    color: '#f59e0b',
    icon: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>',
  },
  Quality: {
    color: '#10b981',
    icon: '<path d="M9 11l3 3 8-8M21 12a9 9 0 1 1-4-7.5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>',
  },
};
---

<section class="workflow-library-shell" data-workflow-library>
  <div class="workflow-library-hero">
    <p class="landing-eyebrow">DISCOVER WORKFLOWS</p>
    <h2>Agent workflows for automation, debugging, demos, and QA</h2>
    <p>
      Explore reusable Gasoline playbooks. Search by outcome, filter by category, and sort by recency or impact.
    </p>
  </div>

  <div class="workflow-controls">
    <label class="search-control">
      <span class="sr-only">Search workflows</span>
      <input
        type="search"
        placeholder="Search workflows..."
        data-workflow-search
        autocomplete="off"
      />
    </label>

    <label>
      <span class="sr-only">Filter category</span>
      <select data-workflow-filter>
        {
          categories.map((category) => (
            <option value={category === 'All' ? 'all' : category}>{category}</option>
          ))
        }
      </select>
    </label>

    <label>
      <span class="sr-only">Sort workflows</span>
      <select data-workflow-sort>
        <option value="newest">Newest first</option>
        <option value="impact">Highest impact</option>
        <option value="title">Title A-Z</option>
      </select>
    </label>

    <p class="workflow-count" data-workflow-count>
      Showing {workflowsByNewest.length} of {workflowsByNewest.length} workflows
    </p>
  </div>

  <div class="workflow-grid" data-workflow-grid>
    {
      workflowsByNewest.map((workflow) => (
        <article
          class="workflow-card"
          data-workflow-card
          data-category={workflow.category}
          data-title={workflow.title.toLowerCase()}
          data-updated={workflow.updatedAt}
          data-impact={workflow.impactScore}
          data-search={`${workflow.title} ${workflow.summary} ${workflow.highlights.join(' ')} ${workflow.category}`.toLowerCase()}
          style={`--wf-color: ${categoryMeta[workflow.category].color}`}
        >
          <div class="workflow-card-top">
            <span class="workflow-category">
              <svg class="workflow-category-icon" viewBox="0 0 24 24" width="16" height="16" aria-hidden="true" set:html={categoryMeta[workflow.category].icon} />
              Topic: {workflow.category}
            </span>
            <span class="workflow-runtime">Reading time: {workflow.runtime}</span>
          </div>
          <h3>{workflow.title}</h3>
          <p>{workflow.summary}</p>
          <ul>
            {workflow.highlights.map((item) => <li>{item}</li>)}
          </ul>
          <div class="workflow-card-bottom">
            <span>Updated {workflow.updatedAt}</span>
            <a href={workflow.docPath}>Open guide</a>
          </div>
        </article>
      ))
    }
  </div>

  <p class="workflow-empty" data-workflow-empty hidden>
    No workflows match this filter. Try a different keyword or category.
  </p>
</section>

<script>
  const root = document.querySelector('[data-workflow-library]');

  if (root) {
    const searchInput = root.querySelector('[data-workflow-search]');
    const filterSelect = root.querySelector('[data-workflow-filter]');
    const sortSelect = root.querySelector('[data-workflow-sort]');
    const cards = Array.from(root.querySelectorAll('[data-workflow-card]'));
    const countLabel = root.querySelector('[data-workflow-count]');
    const emptyState = root.querySelector('[data-workflow-empty]');

    const applyFilters = () => {
      if (!searchInput || !filterSelect || !sortSelect || !countLabel || !emptyState) {
        return;
      }

      const query = searchInput.value.trim().toLowerCase();
      const category = filterSelect.value;
      const sortMode = sortSelect.value;

      const visibleCards = cards.filter((card) => {
        const cardSearch = (card.dataset.search || '').toLowerCase();
        const cardCategory = card.dataset.category || '';
        const queryMatch = !query || cardSearch.includes(query);
        const categoryMatch = category === 'all' || cardCategory === category;
        return queryMatch && categoryMatch;
      });

      const comparators = {
        newest: (a, b) => (b.dataset.updated || '').localeCompare(a.dataset.updated || ''),
        impact: (a, b) => Number(b.dataset.impact || 0) - Number(a.dataset.impact || 0),
        title: (a, b) => (a.dataset.title || '').localeCompare(b.dataset.title || ''),
      };

      visibleCards.sort(comparators[sortMode] || comparators.newest);

      cards.forEach((card) => {
        card.hidden = true;
      });

      visibleCards.forEach((card, index) => {
        card.hidden = false;
        card.style.order = String(index);
      });

      countLabel.textContent = `Showing ${visibleCards.length} of ${cards.length} workflows`;
      emptyState.hidden = visibleCards.length > 0;
    };

    searchInput?.addEventListener('input', applyFilters);
    filterSelect?.addEventListener('change', applyFilters);
    sortSelect?.addEventListener('change', applyFilters);
    applyFilters();
  }
</script>
