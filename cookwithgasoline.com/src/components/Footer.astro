---
// Footer.astro — Custom Gasoline Agentic Devtools footer with Sparky mascot
// Overrides Starlight's default Footer component
import Default from '@astrojs/starlight/components/Footer.astro';
---

<Default><slot /></Default>

<footer class="gasoline-footer">
  <div class="gasoline-footer-content">
    <img src="/images/sparky-relaxed-hammock-1-web.webp" alt="Sparky relaxing" class="gasoline-footer-sparky" />
    <div class="gasoline-footer-copy">
      <p>Gasoline Agentic Devtools &copy; 2025-2026 and crafted with care by <a href="https://www.linkedin.com/in/brennhill/" target="_blank" rel="noopener">Brenn Hill</a>. <em>Pouring fuel on the AI development fire.</em></p>
      <p class="gasoline-footer-blogline">Read the latest updates on the <a href="/blog/">Blog</a>.</p>
    </div>
  </div>
</footer>
